# Copy to .env locally or set as cloud environment variables.
APP_ENV=local
# Local dev: relative path. Docker overrides this to sqlite:////data/fronei.db (named volume).
DATABASE_URL=sqlite:///./fronei.db
ALLOWED_ORIGINS=http://localhost:3000

# Provider keys. Only set the providers you want to use.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
TAVILY_API_KEY=
BRAVE_API_KEY=

# Optional defaults
DEFAULT_PROFILE=balanced
DAILY_BUDGET_USD=10

# Per-user rate limits (sliding window). Admins are exempt.
RATE_LIMIT_CHAT_PER_MINUTE=20
RATE_LIMIT_DOCUMENTS_PER_MINUTE=10
RATE_LIMIT_RESEARCH_PER_HOUR=10
RATE_LIMIT_EXTRACTION_PER_HOUR=5

# Clerk authentication (Clerk Dashboard → API Keys → Frontend API URL)
CLERK_ISSUER=
# Required when APP_ENV=production — see docs/deployment.md. Optional for local dev.
CLERK_AUDIENCE=

# Comma-separated admin allowlists. Use Clerk user IDs for strongest matching.
ADMIN_USER_IDS=
ADMIN_EMAILS=
