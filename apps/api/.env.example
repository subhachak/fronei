# Copy to .env locally or set as cloud environment variables.
APP_ENV=local
# Local dev: relative path. Docker overrides this to sqlite:////data/fronei.db (named volume).
DATABASE_URL=sqlite:///./fronei.db
ALLOWED_ORIGINS=http://localhost:3000

# Operational telemetry. JSON logs are recommended in production.
LOG_LEVEL=INFO
LOG_JSON=false
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.05
APP_RELEASE=

# Provider keys. Only set the providers you want to use.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
TAVILY_API_KEY=
BRAVE_API_KEY=

# Optional defaults
DEFAULT_PROFILE=balanced
DAILY_BUDGET_USD=10

# Per-user rate limits (sliding window). Admins are exempt.
RATE_LIMIT_CHAT_PER_MINUTE=20
RATE_LIMIT_DOCUMENTS_PER_MINUTE=10
RATE_LIMIT_RESEARCH_PER_HOUR=10
RATE_LIMIT_EXTRACTION_PER_HOUR=5

# Clerk authentication (Clerk Dashboard → API Keys → Frontend API URL)
CLERK_ISSUER=
# Required when APP_ENV=production — see docs/deployment.md. Optional for local dev.
CLERK_AUDIENCE=

# Comma-separated admin allowlists. Use Clerk user IDs for strongest matching.
ADMIN_USER_IDS=
ADMIN_EMAILS=

# Concurrency caps for parallel LLM/extraction work. Each concurrent worker
# holds its own request/response buffers in memory at the same time.
# Defaults below are tuned for 512MB instances (e.g. Railway starter plan).
# On larger instances you can raise these (defaults: 4 / 6 / 5 / 4).
MAX_QUESTION_WORKERS=2
MAX_CLAIM_EXTRACT_WORKERS=3
MAX_DOCUMENT_WORKERS=2
MAX_DECOMPOSE_WORKERS=2
