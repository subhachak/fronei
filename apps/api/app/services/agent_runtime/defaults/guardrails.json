{
  "_comment": "applies_to accepts boundary selectors such as tool_pre/tool_post/output and future per-tool selectors such as tool:web_search. Phase B evaluate_boundary matches boundary selectors only; later enforcement can also filter by tool selectors.",
  "policies": [
  {
    "id": "tool.ssrf_prevention",
    "name": "Prevent server-side request forgery",
    "applies_to": ["tool_pre", "tool:web_search", "tool:read_url"],
    "checks": [
      {"type": "url_public_network_only"},
      {"type": "block_private_ip_ranges"}
    ],
    "action_map": {"fail": "block", "pass": "allow"},
    "severity": "critical",
    "enabled": true,
    "version": "1.0.0"
  },
  {
    "id": "tool.output_sanitize",
    "name": "Sanitize external tool output",
    "applies_to": ["tool_post", "output", "tool:web_search", "tool:read_url", "tool:deep_research"],
    "checks": [
      {"type": "strip_tool_instructions"},
      {"type": "require_source_manifest"}
    ],
    "action_map": {"fail": "transform", "pass": "allow"},
    "severity": "high",
    "enabled": true,
    "version": "1.0.0"
  },
  {
    "id": "document.template_ownership",
    "name": "Enforce document template ownership",
    "applies_to": ["tool_pre", "tool:generate_document", "tool:render_pptx"],
    "checks": [
      {"type": "template_belongs_to_user"},
      {"type": "no_silent_default_template_fallback"}
    ],
    "action_map": {"fail": "block", "pass": "allow"},
    "severity": "critical",
    "enabled": true,
    "version": "1.0.0"
  }
  ]
}
