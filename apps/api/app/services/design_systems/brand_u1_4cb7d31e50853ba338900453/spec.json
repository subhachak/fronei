{
  "meta": {
    "name": "AgentDeck Design System \u2014 Brand (brand_u1_4cb7d31e50853ba338900453)",
    "version": "1.0.0",
    "target": "PowerPoint (.pptx) via PptxGenJS",
    "slide_layout": "LAYOUT_WIDE",
    "slide_width_inches": 13.3,
    "slide_height_inches": 7.5,
    "themes": [
      "dark",
      "light"
    ],
    "description": "Token-based design system for AI-generated client presentation decks. All values are in PptxGenJS-compatible units (inches for layout, pt for type, hex strings without # prefix). Brand variant generated from uploaded template '4cb7d31e50853ba338900453' (#181); slide_layouts/components inherited verbatim from 'agentdeck_v1'."
  },
  "color_tokens": {
    "dark": {
      "comment": "Dark theme \u2014 primary bg near-black, surfaces layered upward",
      "bg": {
        "canvas": "0D0F14",
        "surface_1": "151820",
        "surface_2": "1C2028",
        "surface_3": "242834",
        "overlay": "0D0F14CC"
      },
      "accent": {
        "primary": "0C865D",
        "primary_muted": "122F2A",
        "secondary": "2563EB",
        "secondary_muted": "18274A",
        "gold": "E8A838",
        "gold_muted": "8B6420",
        "danger": "E05555",
        "danger_muted": "7A2222",
        "success": "3DC97A",
        "success_muted": "1A6636"
      },
      "text": {
        "primary": "F2F4F8",
        "secondary": "9BA3B4",
        "muted": "5C6476",
        "on_accent": "FFFFFF",
        "on_dark_surface": "D8DCE8"
      },
      "border": {
        "subtle": "1E2330",
        "default": "2A3040",
        "strong": "3C4560"
      },
      "chart": {
        "series_1": "0C865D",
        "series_2": "2563EB",
        "series_3": "E8A838",
        "series_4": "E05555",
        "series_5": "A974E8",
        "grid": "1E2330"
      }
    },
    "light": {
      "comment": "Light theme \u2014 white canvas, subtle gray surfaces",
      "bg": {
        "canvas": "FFFFFF",
        "surface_1": "F4F6FA",
        "surface_2": "EAEDF4",
        "surface_3": "DDE2EE",
        "overlay": "FFFFFFCC"
      },
      "accent": {
        "primary": "0C865D",
        "primary_muted": "CAE4DB",
        "secondary": "2563EB",
        "secondary_muted": "CFDDFB",
        "gold": "B87C0A",
        "gold_muted": "FDF3E0",
        "danger": "C0392B",
        "danger_muted": "FAEAEA",
        "success": "1A7F44",
        "success_muted": "E6F4EA"
      },
      "text": {
        "primary": "0F1520",
        "secondary": "4A5468",
        "muted": "8A94A8",
        "on_accent": "FFFFFF",
        "on_light_surface": "2A3248"
      },
      "border": {
        "subtle": "E8ECF4",
        "default": "D0D6E8",
        "strong": "A8B2CC"
      },
      "chart": {
        "series_1": "0C865D",
        "series_2": "2563EB",
        "series_3": "B87C0A",
        "series_4": "C0392B",
        "series_5": "7B42C8",
        "grid": "E8ECF4"
      }
    }
  },
  "typography": {
    "fontFace": {
      "heading": "Aptos",
      "body": "Aptos Display",
      "mono": "Courier New",
      "fallback": "Arial"
    },
    "scale": {
      "display": {
        "name": "display",
        "usage": "Title slide hero text",
        "fontSize_pt": 52,
        "fontFace": "Aptos",
        "bold": true,
        "lineSpacingMultiple": 1.1
      },
      "h1": {
        "name": "h1",
        "usage": "Slide title / section header",
        "fontSize_pt": 28,
        "fontFace": "Aptos",
        "bold": true,
        "lineSpacingMultiple": 1.2
      },
      "h2": {
        "name": "h2",
        "usage": "Card headers, sub-section titles",
        "fontSize_pt": 18,
        "fontFace": "Aptos",
        "bold": true,
        "lineSpacingMultiple": 1.2
      },
      "h3": {
        "name": "h3",
        "usage": "Component labels, table headers",
        "fontSize_pt": 13,
        "fontFace": "Aptos Display",
        "bold": true,
        "lineSpacingMultiple": 1.2
      },
      "body": {
        "name": "body",
        "usage": "Body copy, bullet points",
        "fontSize_pt": 11,
        "fontFace": "Aptos Display",
        "bold": false,
        "lineSpacingMultiple": 1.4
      },
      "body_sm": {
        "name": "body_sm",
        "usage": "Captions, footnotes, supporting text",
        "fontSize_pt": 9.5,
        "fontFace": "Aptos Display",
        "bold": false,
        "lineSpacingMultiple": 1.3
      },
      "label": {
        "name": "label",
        "usage": "Badge text, tag text, overline labels",
        "fontSize_pt": 9,
        "fontFace": "Aptos Display",
        "bold": true,
        "charSpacing": 3,
        "lineSpacingMultiple": 1.0
      },
      "stat": {
        "name": "stat",
        "usage": "Large metric / KPI numbers on stat cards",
        "fontSize_pt": 36,
        "fontFace": "Aptos",
        "bold": true,
        "lineSpacingMultiple": 1.0
      },
      "stat_sm": {
        "name": "stat_sm",
        "usage": "Medium metric numbers",
        "fontSize_pt": 24,
        "fontFace": "Aptos",
        "bold": true,
        "lineSpacingMultiple": 1.0
      }
    }
  },
  "spacing": {
    "unit_inches": 0.08,
    "comment": "All spacing in inches. Grid unit = 0.08in \u2248 5.75px at 72dpi.",
    "tokens": {
      "xs": 0.08,
      "sm": 0.16,
      "md": 0.24,
      "lg": 0.4,
      "xl": 0.6,
      "2xl": 0.8,
      "3xl": 1.2
    },
    "slide_margins": {
      "top": 0.5,
      "right": 0.5,
      "bottom": 0.5,
      "left": 0.5,
      "content_top": 1.1,
      "comment": "content_top accounts for header bar height (1.0in) + gap (0.1in)"
    },
    "content_area": {
      "x_start": 0.5,
      "y_start": 1.1,
      "width": 12.3,
      "height": 6.0
    }
  },
  "elevation": {
    "comment": "Shadow system for cards and floating elements (PptxGenJS shadow object)",
    "none": null,
    "card": {
      "type": "outer",
      "color": "000000",
      "blur": 8,
      "offset": 3,
      "angle": 45,
      "opacity": 0.1
    },
    "card_hover": {
      "type": "outer",
      "color": "000000",
      "blur": 14,
      "offset": 5,
      "angle": 45,
      "opacity": 0.15
    },
    "floating": {
      "type": "outer",
      "color": "000000",
      "blur": 20,
      "offset": 8,
      "angle": 45,
      "opacity": 0.18
    }
  },
  "radius": {
    "comment": "rectRadius values for PptxGenJS ROUNDED_RECTANGLE. Always use makeShadow() factory to avoid object mutation bug.",
    "none": 0,
    "sm": 0.05,
    "md": 0.08,
    "lg": 0.12,
    "pill": 0.25
  },
  "grid": {
    "comment": "Column grid for content layout. All values in inches.",
    "columns": 12,
    "gutter": 0.2,
    "margin": 0.5,
    "usable_width": 12.3,
    "col_width": 0.9083,
    "presets": {
      "full": {
        "cols": 12,
        "width": 12.3
      },
      "half": {
        "cols": 6,
        "width": 5.95
      },
      "third": {
        "cols": 4,
        "width": 3.9
      },
      "quarter": {
        "cols": 3,
        "width": 2.875
      },
      "two_thirds": {
        "cols": 8,
        "width": 8.0
      },
      "one_third": {
        "cols": 4,
        "width": 3.9
      },
      "sidebar_L": {
        "left": 4.0,
        "right": 7.9,
        "gutter": 0.4
      },
      "sidebar_R": {
        "left": 7.9,
        "right": 4.0,
        "gutter": 0.4
      }
    }
  },
  "components": {
    "header_bar": {
      "description": "Top navigation / section label bar, spans full slide width",
      "x": 0,
      "y": 0,
      "w": 13.3,
      "h": 1.0,
      "shape": "RECTANGLE",
      "fill_token": "bg.canvas (dark) | accent.primary (dark accent) | text.primary (for dark contrast header)",
      "text": {
        "content": "SECTION_NUMBER  |  SECTION_TITLE",
        "x_offset": 0.5,
        "y_center": 0.5,
        "type_token": "label",
        "color_token": "text.on_accent",
        "charSpacing": 4
      },
      "variants": {
        "dark_navy": {
          "fill": "bg.canvas",
          "text_color": "text.primary"
        },
        "accent_blue": {
          "fill": "accent.primary",
          "text_color": "text.on_accent"
        },
        "surface": {
          "fill": "bg.surface_1",
          "text_color": "text.secondary"
        }
      }
    },
    "card": {
      "description": "Generic content card \u2014 the primary building block",
      "shape": "ROUNDED_RECTANGLE",
      "radius_token": "radius.md",
      "padding": {
        "x": 0.2,
        "y": 0.18
      },
      "elevation_token": "elevation.card",
      "variants": {
        "default": {
          "fill_token": "bg.canvas (light) | bg.surface_1 (dark)",
          "border_token": "border.subtle",
          "border_width": 0
        },
        "outlined": {
          "fill_token": "bg.canvas (light) | bg.surface_1 (dark)",
          "border_token": "border.default",
          "border_width_pt": 0.5
        },
        "filled": {
          "fill_token": "bg.surface_2",
          "border_token": "border.subtle",
          "border_width_pt": 0
        },
        "accent": {
          "fill_token": "accent.primary_muted",
          "border_token": "accent.primary",
          "border_width_pt": 0.75
        }
      },
      "color_card_variants": {
        "description": "Solid-color header cards \u2014 use for category differentiation",
        "blue": {
          "header_fill": "accent.primary",
          "header_text": "text.on_accent",
          "body_fill": "bg.canvas"
        },
        "teal": {
          "header_fill": "accent.secondary",
          "header_text": "text.on_accent",
          "body_fill": "bg.canvas"
        },
        "gold": {
          "header_fill": "accent.gold",
          "header_text": "text.on_accent",
          "body_fill": "bg.canvas"
        },
        "danger": {
          "header_fill": "accent.danger",
          "header_text": "text.on_accent",
          "body_fill": "bg.canvas"
        },
        "success": {
          "header_fill": "accent.success",
          "header_text": "text.on_accent",
          "body_fill": "bg.canvas"
        },
        "surface": {
          "header_fill": "bg.surface_3",
          "header_text": "text.primary",
          "body_fill": "bg.canvas"
        }
      }
    },
    "stat_card": {
      "description": "KPI / metric display card",
      "layout": "vertical",
      "elements": [
        {
          "slot": "icon",
          "optional": true,
          "size_in": 0.45,
          "position": "top-left"
        },
        {
          "slot": "value",
          "required": true,
          "type_token": "stat",
          "color_token": "text.primary"
        },
        {
          "slot": "label",
          "required": true,
          "type_token": "body",
          "color_token": "text.secondary"
        },
        {
          "slot": "delta",
          "optional": true,
          "type_token": "body_sm",
          "color_token": "accent.success | accent.danger"
        },
        {
          "slot": "caption",
          "optional": true,
          "type_token": "body_sm",
          "color_token": "text.muted"
        }
      ],
      "min_width_in": 2.4,
      "min_height_in": 1.6
    },
    "badge": {
      "description": "Small status / category label \u2014 inline pill shape",
      "shape": "ROUNDED_RECTANGLE",
      "radius_token": "radius.pill",
      "type_token": "label",
      "padding": {
        "x": 0.12,
        "y": 0.06
      },
      "variants": {
        "default": {
          "fill": "bg.surface_2",
          "text": "text.secondary"
        },
        "primary": {
          "fill": "accent.primary_muted",
          "text": "accent.primary"
        },
        "success": {
          "fill": "accent.success_muted",
          "text": "accent.success"
        },
        "danger": {
          "fill": "accent.danger_muted",
          "text": "accent.danger"
        },
        "gold": {
          "fill": "accent.gold_muted",
          "text": "accent.gold"
        },
        "solid_primary": {
          "fill": "accent.primary",
          "text": "text.on_accent"
        },
        "solid_danger": {
          "fill": "accent.danger",
          "text": "text.on_accent"
        },
        "solid_success": {
          "fill": "accent.success",
          "text": "text.on_accent"
        },
        "solid_gold": {
          "fill": "accent.gold",
          "text": "text.on_accent"
        }
      }
    },
    "divider": {
      "shape": "RECTANGLE",
      "height_in": 0.04,
      "variants": {
        "subtle": {
          "fill_token": "border.subtle"
        },
        "default": {
          "fill_token": "border.default"
        },
        "accent": {
          "fill_token": "accent.gold"
        },
        "primary": {
          "fill_token": "accent.primary"
        }
      }
    },
    "bullet_list": {
      "type_token": "body",
      "color_token": "text.primary",
      "bullet_style": "bullet: true (PptxGenJS built-in)",
      "indent_levels": {
        "0": {
          "indent": 0,
          "fontSize_pt": 11
        },
        "1": {
          "indent": 0.15,
          "fontSize_pt": 10.5,
          "color_token": "text.secondary"
        }
      },
      "item_spacing_pt": 4,
      "paraSpaceAfter_pt": 4,
      "icon_bullet": {
        "description": "Replace default bullet with an icon image",
        "icon_size_in": 0.25,
        "icon_x_offset": 0.18,
        "text_x_offset": 0.5
      }
    },
    "table": {
      "description": "Data table for comparisons and structured data",
      "header_row": {
        "fill_token": "bg.canvas (dark) | text.primary (dark)",
        "text_token": "h3",
        "text_color_token": "text.on_accent (dark header) | text.primary (light header)",
        "height_in": 0.5
      },
      "body_row": {
        "even_fill_token": "bg.canvas",
        "odd_fill_token": "bg.surface_1",
        "text_token": "body",
        "text_color_token": "text.primary",
        "height_in": 0.48
      },
      "cell_padding_in": 0.1,
      "border": {
        "color_token": "border.subtle",
        "width_pt": 0
      },
      "semantic_cell_colors": {
        "critical": {
          "text": "accent.danger",
          "bold": true
        },
        "warning": {
          "text": "accent.gold",
          "bold": false
        },
        "positive": {
          "text": "accent.success",
          "bold": false
        },
        "muted": {
          "text": "text.muted",
          "bold": false
        }
      }
    },
    "callout_bar": {
      "description": "Full-width insight / key takeaway banner at bottom of slide",
      "shape": "ROUNDED_RECTANGLE",
      "radius_token": "radius.md",
      "x": 0.4,
      "h_in": 0.9,
      "width": 12.5,
      "padding_left_in": 0.6,
      "icon_size_in": 0.45,
      "text_x_offset": 1.3,
      "type_token": "body",
      "variants": {
        "insight": {
          "fill_token": "accent.gold_muted",
          "icon_color": "accent.gold",
          "text_color": "text.primary"
        },
        "info": {
          "fill_token": "accent.primary_muted",
          "icon_color": "accent.primary",
          "text_color": "text.primary"
        },
        "danger": {
          "fill_token": "accent.danger_muted",
          "icon_color": "accent.danger",
          "text_color": "text.primary"
        },
        "success": {
          "fill_token": "accent.success_muted",
          "icon_color": "accent.success",
          "text_color": "text.primary"
        }
      }
    },
    "progress_bar": {
      "description": "Horizontal progress / completion indicator",
      "track_shape": "ROUNDED_RECTANGLE",
      "track_fill_token": "bg.surface_3",
      "fill_shape": "ROUNDED_RECTANGLE",
      "fill_color_token": "accent.primary",
      "height_in": 0.14,
      "radius_token": "radius.pill",
      "label_type_token": "body_sm",
      "label_color_token": "text.secondary"
    },
    "icon_circle": {
      "description": "Icon inside a colored circle \u2014 used in numbered steps, feature lists",
      "shape": "OVAL",
      "sizes": {
        "sm": {
          "diameter_in": 0.45,
          "icon_size_in": 0.25
        },
        "md": {
          "diameter_in": 0.65,
          "icon_size_in": 0.38
        },
        "lg": {
          "diameter_in": 0.9,
          "icon_size_in": 0.5
        }
      }
    },
    "timeline_node": {
      "description": "Single step in a horizontal or vertical timeline",
      "elements": [
        {
          "slot": "connector_line",
          "shape": "RECTANGLE",
          "fill_token": "border.default"
        },
        {
          "slot": "node_circle",
          "shape": "OVAL",
          "fill_token": "accent.primary"
        },
        {
          "slot": "step_label",
          "type_token": "label"
        },
        {
          "slot": "title",
          "type_token": "h3"
        },
        {
          "slot": "body",
          "type_token": "body_sm",
          "optional": true
        }
      ]
    }
  },
  "slide_layouts": {
    "description": "Named layout templates. Each layout defines zones with x, y, w, h in inches. Agent fills each zone with appropriate components.",
    "common_rules": [
      "Always include header_bar at y=0, h=1.0",
      "Content area starts at y=1.1 with 0.5in left/right margin",
      "All card arrays use gap of 0.2in between items",
      "Never place content below y=7.1 (leaves 0.4in bottom margin)",
      "Use makeShadow() factory for all shadow objects to prevent PptxGenJS mutation bug"
    ],
    "TITLE": {
      "name": "Title Slide",
      "usage": "Opening slide. No header bar.",
      "zones": {
        "left_panel": {
          "x": 0,
          "y": 0,
          "w": 4.8,
          "h": 7.5,
          "fill_token": "accent.secondary",
          "contains": [
            "brand_icon",
            "deck_type_label",
            "date_label",
            "confidentiality"
          ]
        },
        "hero_title": {
          "x": 5.2,
          "y": 0.7,
          "w": 7.8,
          "h": 3.6,
          "type_token": "display",
          "color_token": "text.primary"
        },
        "accent_rule": {
          "x": 5.2,
          "y": 4.4,
          "w": 7.8,
          "h": 0.05,
          "fill_token": "accent.gold"
        },
        "subtitle": {
          "x": 5.2,
          "y": 4.6,
          "w": 7.8,
          "h": 1.2,
          "type_token": "h2",
          "color_token": "text.secondary"
        },
        "presenter": {
          "x": 5.2,
          "y": 6.8,
          "w": 7.8,
          "h": 0.4,
          "type_token": "body_sm",
          "color_token": "text.muted"
        }
      }
    },
    "SECTION_HEADER": {
      "name": "Section Header / Divider",
      "usage": "Between major deck sections",
      "zones": {
        "bg_full": {
          "x": 0,
          "y": 0,
          "w": 13.3,
          "h": 7.5,
          "fill_token": "bg.canvas"
        },
        "accent_stripe": {
          "x": 0,
          "y": 0,
          "w": 0.6,
          "h": 7.5,
          "fill_token": "accent.primary"
        },
        "section_number": {
          "x": 1.0,
          "y": 2.8,
          "w": 1.5,
          "h": 1.0,
          "type_token": "display",
          "color_token": "accent.primary",
          "opacity": 0.15
        },
        "section_title": {
          "x": 1.0,
          "y": 3.0,
          "w": 8.0,
          "h": 1.5,
          "type_token": "display",
          "color_token": "text.primary"
        },
        "section_subtitle": {
          "x": 1.0,
          "y": 4.6,
          "w": 8.0,
          "h": 0.8,
          "type_token": "h2",
          "color_token": "text.secondary"
        }
      }
    },
    "CONTENT_1COL": {
      "name": "Single Column Content",
      "usage": "Full-width text, single large chart, or single wide table",
      "zones": {
        "header_bar": {
          "x": 0,
          "y": 0,
          "w": 13.3,
          "h": 1.0
        },
        "slide_title": {
          "x": 0.5,
          "y": 1.1,
          "w": 12.3,
          "h": 0.6,
          "type_token": "h1"
        },
        "body": {
          "x": 0.5,
          "y": 1.85,
          "w": 12.3,
          "h": 5.2
        }
      }
    },
    "CONTENT_2COL": {
      "name": "Two Column Content",
      "usage": "Side-by-side comparison, text + chart, text + diagram",
      "zones": {
        "header_bar": {
          "x": 0,
          "y": 0,
          "w": 13.3,
          "h": 1.0
        },
        "slide_title": {
          "x": 0.5,
          "y": 1.1,
          "w": 12.3,
          "h": 0.6,
          "type_token": "h1"
        },
        "col_left": {
          "x": 0.5,
          "y": 1.85,
          "w": 5.95,
          "h": 5.2
        },
        "col_right": {
          "x": 6.85,
          "y": 1.85,
          "w": 5.95,
          "h": 5.2
        }
      }
    },
    "CONTENT_3COL": {
      "name": "Three Column Content",
      "usage": "Three parallel cards, comparison of three options, framework pillars",
      "zones": {
        "header_bar": {
          "x": 0,
          "y": 0,
          "w": 13.3,
          "h": 1.0
        },
        "slide_title": {
          "x": 0.5,
