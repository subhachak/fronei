  "generation_rules": {
    "description": "Rules the AI agent MUST follow when generating a deck using this system",
    "mandatory": [
      "NEVER use '#' prefix on hex color strings \u2014 PptxGenJS treats colors as raw hex",
      "ALWAYS use makeShadow() factory function for shadow objects \u2014 never reuse the same object instance",
      "ALWAYS use ROUNDED_RECTANGLE shape for cards with rectRadius, never RECTANGLE with radius",
      "NEVER add accent stripes/bars on card edges \u2014 use fill tint or shadow instead",
      "NEVER use bold/italic unicode bullets \u2014 use bullet: true in PptxGenJS text options",
      "ALWAYS use breakLine: true between bullet items in addText() arrays",
      "NEVER use lineSpacing with bullets \u2014 use paraSpaceAfter instead",
      "ALL font sizes in points (pt), ALL positions in inches",
      "Minimum readable font size: 8pt (absolute floor), prefer 9.5pt+ for body",
      "When choosing between dark/light variants, use the SAME theme consistently across all slides",
      "Header bar on every content slide except TITLE and CLOSING",
      "Slide title font: Cambria (heading). Body font: Calibri. Never mix on same element.",
      "Always add speaker notes via addNotes() \u2014 never put notes in slide text boxes",
      "QA: always generate slide thumbnails and inspect for overflow before delivering"
    ],
    "theme_switching": {
      "description": "How to resolve tokens for each theme at generation time",
      "dark": "Use color_tokens.dark.* for all fill, text, and border values",
      "light": "Use color_tokens.light.* for all fill, text, and border values",
      "token_resolution_example": {
        "token": "accent.primary",
        "dark": "4F8EF7",
        "light": "1A5FC8"
      }
    },
    "icon_handling": {
      "library": "react-icons",
      "render_method": "ReactDOMServer.renderToStaticMarkup \u2192 sharp PNG conversion \u2192 base64",
      "size_for_render": 256,
      "install": "npm install -g react-icons react react-dom sharp",
      "icon_size_on_slide": "Match icon_circle.sizes or component spec \u2014 typically 0.3\u20130.5in"
    },
    "chart_colors": {
      "rule": "Always use chart.series_1 through series_5 from the active theme",
      "chart_area_fill": "bg.canvas",
      "axis_label_color": "text.secondary",
      "grid_line_color": "chart.grid"
    }
  },
  "token_pairs": {
    "description": "Reusable semantic fill/text token groupings, resolved per-theme via color_tokens.{dark,light} through resolve_color()/resolve_token(). Generalizes the badge/callout_bar variants fill/text/icon pattern and the stat_card delta conditional color_token (accent.success | accent.danger) into named, theme-safe pairs so new components do not hardcode raw token paths.",
    "default": {
      "fill": "bg.surface_2",
      "text": "text.secondary",
      "solid_fill": "bg.surface_3",
      "solid_text": "text.primary"
    },
    "primary": {
      "fill": "accent.primary_muted",
      "text": "accent.primary",
      "solid_fill": "accent.primary",
      "solid_text": "text.on_accent"
    },
    "secondary": {
      "fill": "accent.secondary_muted",
      "text": "accent.secondary",
      "solid_fill": "accent.secondary",
      "solid_text": "text.on_accent"
    },
    "gold": {
      "fill": "accent.gold_muted",
      "text": "accent.gold",
      "solid_fill": "accent.gold",
      "solid_text": "text.on_accent"
    },
    "success": {
      "fill": "accent.success_muted",
      "text": "accent.success",
      "solid_fill": "accent.success",
      "solid_text": "text.on_accent"
    },
    "danger": {
      "fill": "accent.danger_muted",
      "text": "accent.danger",
      "solid_fill": "accent.danger",
      "solid_text": "text.on_accent"
    },
    "conditional": {
      "description": "Maps a semantic condition to a token_pairs key above. Used for slots whose color depends on data (e.g. stat_card.delta sign).",
      "stat_delta": {
        "positive": "success",
        "negative": "danger",
        "neutral": "default"
      }
    }
  },
  "qa_thresholds": {
    "description": "Numeric thresholds consumed by plan_checks.py (pre-render structural QA) and render_checks.py (post-render visual QA) -- see #147. Theme-independent.",
    "contrast": {
      "min_ratio_normal_text": 4.5,
      "min_ratio_large_text": 3.0,
      "large_text_pt": 18
    },
    "min_font_pt": {
      "body": 11,
      "body_sm": 9,
      "label": 8,
      "stat_sm": 14
    },
    "max_chars": {
      "title": 60,
      "dek": 120,
      "bullet_item": 110,
      "card_title": 40,
      "card_body": 160,
      "callout": 140,
      "stat_label": 30,
      "stat_caption": 60,
      "table_cell": 60
    },
    "max_items": {
      "bullet_list": 6,
      "card_grid": 4,
      "stat_strip": 4,
      "timeline": 6,
      "table_rows": 8,
      "decision_list": 4
    },
    "whitespace": {
      "min_zone_fill_pct": 0.15,
      "max_empty_zone_pct": 0.35
    }
  }
